# ── Banco de dados ──────────────────────────────────────────────
# Deixe DB_TYPE vazio ou "sqlite" para desenvolvimento local
DB_TYPE=postgres

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=scoutplay
PG_USERNAME=scoutplay_user
PG_PASSWORD=scoutplay_pass
PG_SSLMODE=prefer

# ── Keycloak ─────────────────────────────────────────────────────
KEYCLOACK_SERVER_URL=https://auth.seudominio.com.br
KEYCLOACK_REALM=scoutplay
KEYCLOACK_CLIENT_ID=scoutplay-api
KEYCLOACK_CLIENT_SECRET=your-client-secret

# ── Azure Blob Storage ───────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_NAME=scoutplay-files

# ── Azure Notification Hub ───────────────────────────────────────
AZURE_NOTIFICATION_HUB_CONNECTION_STRING=Endpoint=sb://...
AZURE_NOTIFICATION_HUB_NAME=scoutplay-hub

# ── Firebase ─────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=scoutplay-firebase

# ── VAPID (Web Push) ─────────────────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App ──────────────────────────────────────────────────────────
SCOUTPLAY_APP_URL=https://scoutplay.syncplus.com.br
LOG_LEVEL=INFO
